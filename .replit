modules = ["nodejs-20", "swift-5.8", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["flutter329"]

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx serve build/web -l 5000 -s"
waitForPort = 5000
